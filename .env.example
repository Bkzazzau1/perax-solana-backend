# Pera-X Utility Gateway environment example
# Copy this file to .env and replace values before running locally.

HOST=0.0.0.0
PORT=8080

# Database and cache
DATABASE_URL=postgres://postgres:postgres@localhost:5432/perax
REDIS_URL=redis://127.0.0.1:6379

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
PERAX_ANCHOR_WORKSPACE=C:\PROJECTS\smartcontract PEX\perax-ecosystem\perax-contracts
PERAX_PROGRAM_ID=11111111111111111111111111111111

# Trading Company SPL token account
# IMPORTANT:
# This must be the SPL token account that holds Pera-X tokens for the Trading Company.
# It is not the normal wallet address. The wallet owner controls this token account.
# Backend payment confirmation, utility grants, and approved burns use this account.
TRADING_CO_TREASURY=replace-with-trading-company-spl-token-account

# Burn execution mode
# manual   = declare/store burn decisions only; no execution
# approved = execute only approved burn decisions
BURN_EXECUTION_MODE=manual

# Security
JWT_SECRET=replace-with-at-least-32-characters-secret

# External providers
CLAUDE_BASE_URL=https://api.anthropic.com
COPYLEAKS_BASE_URL=https://api.copyleaks.com
TELNYX_BASE_URL=https://api.telnyx.com
