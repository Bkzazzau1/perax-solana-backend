# Pera-X Utility Gateway environment example
# Copy this file to .env and replace values before running locally.

HOST=0.0.0.0
PORT=8080

# Database and cache
DATABASE_URL=postgres://postgres:postgres@localhost:5432/perax
REDIS_URL=redis://127.0.0.1:6379

# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
PERAX_ANCHOR_WORKSPACE=C:/PROJECTS/Pera-X-ecosystem/perax-contracts

# Deployed Pera-X devnet program and token records
PERAX_PROGRAM_ID=FqEiSx5vujh2vi3yk12NaZMXhjMSaKovGUuzcKiAgshn
PERAX_STATE_PDA=8LNUe8ud9Lrtt1HmuS132YoGs5tBNEeWeviNJwWDkHWT
PEX_MINT_ADDRESS=DnkAW3B1ckzW6eimgSBNPK3XTt83wMiZRETy8iF3gdsn

# PEX fixed-supply token policy
PEX_TOKEN_NAME=Pera-X
PEX_TOKEN_SYMBOL=PEX
PEX_TOTAL_SUPPLY=1000000000
PEX_DECIMALS=6
PEX_INITIAL_PRICE_USD=0.000012
PEX_FIXED_SUPPLY=true
PEX_MINT_AUTHORITY_REVOKED=true

# Meteora DLMM launch liquidity
PEX_LIQUIDITY_VENUE=Meteora DLMM
PEX_LIQUIDITY_PAIR=PEX/USDC
PEX_INITIAL_LIQUIDITY_PERCENTAGE=38
PEX_INITIAL_LIQUIDITY_AMOUNT=380000000
PEX_INITIAL_LIQUIDITY_QUOTE_USD=4560

# Devnet mock quote token for liquidity testing
MOCK_USDC_MINT=FABf7w6NDdR3EgNrFkQpsbQLFMJTpJLuhMjmPbwj1Une
LP_MOCK_USDC_TOKEN_ACCOUNT=6B8wZx3eqHUJhS9DbE7BTLLbve2nucBFnXmVedjDNw8o

# Market-condition unlocking policy
PEX_MARKET_MONITOR_INTERVAL_MINUTES=10
PEX_TWAP_CONFIRMATION_MINUTES_MIN=30
PEX_TWAP_CONFIRMATION_MINUTES_MAX=60
PEX_UNLOCK_COOLDOWN_HOURS_MIN=2
PEX_UNLOCK_COOLDOWN_HOURS_MAX=6
PEX_MAX_DAILY_UNLOCK_AMOUNT=10000000
PEX_MAX_DAILY_UNLOCK_PERCENTAGE=1
PEX_UNLOCK_REQUIRES_MANUAL_APPROVAL=false
PEX_UNLOCK_EMERGENCY_PAUSE_ENABLED=true

# Trading Company SPL token accounts
# TRADING_COMPANY_TOKEN_ACCOUNT = locked/strategic token account.
# TRADING_COMPANY_REVENUE_TOKEN_ACCOUNT = revenue account for PEX-for-Credits payments and supply-control burns.
# These two accounts must be different.
TRADING_COMPANY_TOKEN_ACCOUNT=Wcx1HaNWZQmtfn1yfS3FWXv7AKSXV8ftciezTX3ufs8
TRADING_COMPANY_REVENUE_TOKEN_ACCOUNT=E4JJoNkKhFq8Ev7XtJhuWrvdyNyWRzkwjsukgF9VbegA
TRADING_CO_TREASURY=Wcx1HaNWZQmtfn1yfS3FWXv7AKSXV8ftciezTX3ufs8
TRADING_COMPANY_SECOND_WALLET=E4JJoNkKhFq8Ev7XtJhuWrvdyNyWRzkwjsukgF9VbegA

# Burn and revenue control policy
# 2% minimum burn, 10% normal/default burn, 30% maximum burn.
# Monthly sell cap must remain 50% under approved PEX policy.
PEX_IMMEDIATE_BURN_PERCENTAGE=10
PEX_MONTHLY_SELL_CAP_PERCENTAGE=50

# Burn execution mode
# manual   = schedule/store burn decisions only; no on-chain execution
# approved = submit scheduled burn decisions to the protected supply-control executor
BURN_EXECUTION_MODE=manual

# Protected supply-control executor
# This must match the executor route:
# supply-control-executor/src/server.js -> POST /execute/market-condition-burn
PERAX_SUPPLY_CONTROL_EXECUTOR_URL=http://127.0.0.1:8787/execute/market-condition-burn
PERAX_SUPPLY_CONTROL_EXECUTOR_TOKEN=replace-with-secure-token

# Security
JWT_SECRET=replace-with-at-least-32-characters-secret

# External providers
CLAUDE_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-latest

COPYLEAKS_BASE_URL=https://api.copyleaks.com
COPYLEAKS_EMAIL=replace-with-copyleaks-email
COPYLEAKS_API_KEY=replace-with-copyleaks-api-key
COPYLEAKS_WEBHOOK_SECRET=replace-with-copyleaks-webhook-secret

TELNYX_BASE_URL=https://api.telnyx.com
TELNYX_API_KEY=replace-with-telnyx-api-key
TELNYX_MESSAGING_PROFILE_ID=replace-with-telnyx-messaging-profile-id
TELNYX_CONNECTION_ID=replace-with-telnyx-connection-id
TELNYX_FROM_NUMBER=+10000000000
TELNYX_WEBHOOK_PUBLIC_KEY=replace-with-telnyx-webhook-public-key
TELNYX_WEBHOOK_SIGNING_SECRET=replace-with-telnyx-webhook-signing-secret
CREDIT_USD_VALUE=1
TELNYX_SMS_ESTIMATED_USD_COST_PER_SEGMENT=0
TELNYX_VOICE_ESTIMATED_USD_COST_PER_MINUTE=0
TELNYX_NUMBER_ESTIMATED_USD_COST=0
TELNYX_USAGE_REPORT_SYNC_ENABLED=false
TELNYX_USAGE_REPORT_SYNC_INTERVAL_SECONDS=3600
TELNYX_USAGE_REPORT_SYNC_WINDOW_HOURS=24

PAYSCRIBE_BASE_URL=https://api.payscribe.ng
PAYSCRIBE_API_KEY=replace-with-payscribe-api-key
PAYSCRIBE_SECRET_KEY=replace-with-payscribe-secret-key
PAYSCRIBE_WEBHOOK_SECRET=replace-with-payscribe-webhook-secret

STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret

BANK_RAILS_BASE_URL=https://bank-provider.example
BANK_RAILS_API_KEY=replace-with-bank-rails-api-key
BANK_RAILS_WEBHOOK_SECRET=replace-with-bank-rails-webhook-secret

PYTH_PRICE_SERVICE_URL=https://hermes.pyth.network
PYTH_PEX_PRICE_FEED_ID=replace-with-pyth-pex-price-feed-id
PYTH_SOL_PRICE_FEED_ID=replace-with-pyth-sol-price-feed-id

METEORA_API_BASE_URL=https://dlmm-api.meteora.ag
METEORA_DLMM_PAIR_ADDRESS=replace-with-meteora-dlmm-pair-address
